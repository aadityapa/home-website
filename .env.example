# Next.js public env (exposed to browser)
NEXT_PUBLIC_SITE_URL=https://homewebsite-five.vercel.app
NEXT_PUBLIC_PHONE=9423431674

# Catalog source: leave unset for local JSON via /api/catalog
# NEXT_PUBLIC_CATALOG_URL=/data/catalog.json

# Commerce provider flag (set to shopify when Storefront API is configured)
# NEXT_PUBLIC_COMMERCE_PROVIDER=shopify

# Shopify Storefront API (server-only — never expose token to browser)
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxx
# SHOPIFY_API_VERSION=2024-10

# NEXT_PUBLIC_VIDEO_ALLOW_FALLBACK=false
