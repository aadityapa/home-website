# Canonical site origin for SEO: Open Graph, Twitter cards, robots.txt, sitemap.xml, JSON-LD.
# No trailing slash.
VITE_SITE_URL=https://www.example.com

# Asset base path. Use `/Homewebsite/` for GitHub Pages; `/` for custom domain root.
# VITE_BASE_PATH=/

# Optional: full URL to catalog JSON (defaults to /data/catalog.json on your domain).
# VITE_CATALOG_URL=https://cdn.example.com/catalog.json

# Set to "true" only if kitchen-to-table.mp4 is missing locally — plays a sample clip instead.
# VITE_VIDEO_ALLOW_FALLBACK=false
